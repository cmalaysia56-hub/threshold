rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Each user can only read/write documents under their own uid.
    // This is where journal entries, follow-ups, and saved prayers will
    // live once step 2 (migrating storage to Firestore) is done.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Aggregated analytics data is never written or read directly by
    // clients — only the server (via the Firebase Admin SDK, using a
    // service account) can touch this collection. The admin dashboard
    // reads through a server-side API route, not directly from the
    // client, so this stays locked down entirely.
    match /analytics/{document=**} {
      allow read, write: if false;
    }

    // Default deny for anything not explicitly matched above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
